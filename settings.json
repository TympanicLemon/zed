{
  // Main settings
  "theme": "Ultimate Dark Neo",
  "base_keymap": "JetBrains",
  "vim_mode": true,
  // Font settings
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  // Editor settings
  "scrollbar": {
    "show": "never"
  },
  "project_panel": {
    "auto_fold_dirs": true
  },
  "indent_guides": {
    "enabled": false
  },
  // Editing settings
  "tab_size": 2,
  "cursor_blink": false,
  "relative_line_numbers": true,
  "remove_trailing_whitespace_on_save": true,
  "inlay_hints": {
    "enabled": true
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  // Bottom bar ui settings
  // Hide the project panel button
  // Hide the collaboration panel button
  "collaboration_panel": {
    "button": false
  },
  // Hide the chat panel button
  "chat_panel": {
    "button": false
  },
  "assistant": {
    "version": "1",
    "button": false
  },
  // Hide the terminal button in the status bar
  "terminal": {
    "button": false
  }
}
