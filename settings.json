{
    "theme": "Nord",
    "base_keymap": "JetBrains",
    "vim_mode": true,
    "ui_font_size": 16,
    "buffer_font_size": 16,
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "tab_size": 4,
    "cursor_blink": false,
    "relative_line_numbers": true,
    "remove_trailing_whitespace_on_save": true,
    "scrollbar": {
        "show": "never"
    },
    "project_panel": {
        "auto_fold_dirs": true
    },
    "indent_guides": {
        "enabled": true
    },
    "inlay_hints": {
        "enabled": true
    },
    "git": {
        "inline_blame": {
            "enabled": false
        }
    },
    "collaboration_panel": {
        "button": false
    },
    "chat_panel": {
        "button": false
    },
    "assistant": {
        "version": "1",
        "button": false
    },
    "terminal": {
        "button": false
    }
}
